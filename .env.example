# Dine-in App — environment template
# Copy this file to `.env.local` (Vite picks that up automatically) and fill in real values.
# DO NOT commit `.env.local` (it is git-ignored).

# ─────────────────────────────────────────────
# Frontend (Vite) — used by src/lib/n8n.js
# ─────────────────────────────────────────────
# Base URL for the n8n webhook server (no trailing slash)
VITE_N8N_BASE=https://stocktechnicaltradeassistance.zeabur.app

# Default location_id passed with rate-meal feedback (UUID)
VITE_LOCATION_ID=00000000-0000-0000-0000-000000000002

# ─────────────────────────────────────────────
# AWS S3 (used by the n8n workflow Menu_Photo_Presign / Menu_Photo_Upload)
# These are NOT read by the frontend — they live on the n8n server side.
# Listed here so devs deploying their own n8n instance know what to set.
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2
AWS_S3_BUCKET=foodservai-menu-photos
